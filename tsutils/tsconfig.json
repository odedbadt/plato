{
    "compilerOptions": {
        "target": "ES2020",
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "rootDir": "src",
        "outDir": "dist",
        "declaration": true,
        "declarationMap": true,
        "inlineSourceMap": false,
        "sourceMap": true,
        "composite": true,
        "strict": true,
        "tsBuildInfoFile": "./.tsbuildinfo"
    },
    "include": [
        "src"
    ]
}
